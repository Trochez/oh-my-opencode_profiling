{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "model_fallback": true,
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [
      429,
      500,
      502,
      503,
      504,
      529
    ],
    "retry_on_timeout": true,
    "retry_on_network_error": true,
    "max_fallback_attempts": 5,
    "backoff_ms": 1000,
    "max_backoff_ms": 30000,
    "timeout_seconds": 120,
    "cooldown_seconds": 30
  },
  "providerOptions": {
    "enable-auto-tool-choice": true,
    "tool-call-parser": "auto"
  },
  "provider": {
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "timeout": 120000,
        "chunkTimeout": 30000
      },
      "models": {
        "nvidia/nemotron-3-nano-30b-a3b:nitro": {
          "name": "NVIDIA Nemotron 3 Nano 30B A3B Nitro"
        },
        "stepfun/step-3.5-flash": {
          "name": "StepFun Step 3.5 Flash"
        },
        "qwen/qwen3-coder-next": {
          "name": "Qwen3 Coder Next"
        },
        "openai/gpt-5.4-nano": {
          "name": "GPT 5.4 Nano via OpenRouter"
        }
      }
    }
  },
  "background_task": {
    "staleTimeoutMs": 60000,
    "circuitBreaker": {
      "enabled": true,
      "consecutiveThreshold": 50,
      "maxToolCalls": 8000
    }
  },
  "agents": {
    "sisyphus": {
      "model": "openrouter/nvidia/nemotron-3-nano-30b-a3b:nitro",
      "provider": "openrouter",
      "variant": "max",
      "reasoningEffort": "xhigh",
      "temperature": 0.3,
      "top_p": 0.9,
      "maxTokens": 16384,
      "thinking": {
        "type": "enabled",
        "budgetTokens": 10000
      },
      "mode": "primary",
      "category": "orchestrator",
      "skills": [
        "ralph",
        "autopilot",
        "ultrawork"
      ],
      "tools": {
        "bash": true,
        "edit": true,
        "read": true,
        "write": true,
        "task": true,
        "webfetch": true,
        "websearch": true
      },
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "allow",
        "task": "allow"
      },
      "textVerbosity": "medium",
      "color": "#9400D3",
