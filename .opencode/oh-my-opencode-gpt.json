{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "model_fallback": true,
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [
      429,
      500,
      502,
      503,
      504,
      529
    ],
    "retry_on_timeout": true,
    "retry_on_network_error": true,
    "max_fallback_attempts": 5,
    "backoff_ms": 1000,
    "max_backoff_ms": 30000,
    "timeout_seconds": 120,
    "cooldown_seconds": 30
  },
  "providerOptions": {
    "enable-auto-tool-choice": true,
    "tool-call-parser": "auto"
  },
  "provider": {
    "nvidia": {
      "timeout": 120000,
      "chunkTimeout": 30000
    },
    "openai": {
      "timeout": 120000,
      "chunkTimeout": 30000
    },
    "opencode": {
      "timeout": 120000,
      "chunkTimeout": 30000
    }
  },
  "background_task": {
    "staleTimeoutMs": 60000,
    "circuitBreaker": {
      "enabled": true,
      "consecutiveThreshold": 50,
      "maxToolCalls": 8000
    }
  },
  "agents": {
    "sisyphus": {
      "model": "openai/gpt-5.4-pro",
      "variant": "max",
      "reasoningEffort": "xhigh",
      "temperature": 0.3,
      "top_p": 0.9,
      "maxTokens": 16384,
      "thinking": {
        "type": "enabled",
        "budgetTokens": 10000
      },
      "mode": "primary",
      "category": "orchestrator",
      "skills": [
        "ralph",
        "autopilot",
        "ultrawork"
      ],
      "tools": {
        "bash": true,
